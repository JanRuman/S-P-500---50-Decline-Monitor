<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>S&amp;P 500 Decline Monitor</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #f4f6f9;
      color: #1a1a2e;
      margin: 0;
      padding: 24px 16px;
    }

    h1 {
      font-size: 1.6rem;
      margin: 0 0 4px;
    }

    .meta {
      color: #555;
      font-size: 0.85rem;
      margin-bottom: 20px;
    }

    .controls {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 16px;
    }

    .controls input, .controls select {
      padding: 8px 12px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 0.9rem;
      background: #fff;
    }

    .controls input { min-width: 220px; }

    .summary-bar {
      font-size: 0.85rem;
      color: #444;
      margin-bottom: 8px;
    }

    .table-wrap {
      overflow-x: auto;
      border-radius: 8px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.12);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      font-size: 0.88rem;
    }

    thead th {
      background: #1a1a2e;
      color: #fff;
      padding: 11px 14px;
      text-align: left;
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }

    thead th:hover { background: #2d2d52; }

    tbody tr { border-bottom: 1px solid #eee; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: rgba(0,0,0,0.03) !important; }

    tbody td {
      padding: 9px 14px;
      white-space: nowrap;
    }

    /* Severity colour coding */
    tr.severe   { background: #fff0f0; }
    tr.significant { background: #fff7ed; }

    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 12px;
      font-size: 0.78rem;
      font-weight: 600;
    }

    .badge.severe      { background: #fee2e2; color: #b91c1c; }
    .badge.significant { background: #ffedd5; color: #c2410c; }

    .pct { font-weight: 700; }
    .pct.severe      { color: #b91c1c; }
    .pct.significant { color: #c2410c; }

    .ticker { font-weight: 700; font-family: monospace; font-size: 0.92rem; }

    .no-results {
      text-align: center;
      padding: 40px;
      color: #888;
      font-size: 1rem;
    }

    @media (max-width: 600px) {
      h1 { font-size: 1.2rem; }
    }
  </style>
</head>
<body>

<h1>S&amp;P 500 — Stocks Down {{ threshold | int }}%+ from All-Time High</h1>
<p class="meta">
  Generated: <strong>{{ generated_at }}</strong> &nbsp;|&nbsp;
  Threshold: <strong>{{ threshold | int }}%</strong> &nbsp;|&nbsp;
  Min market cap: <strong>${{ min_market_cap_b | int }}B</strong> &nbsp;|&nbsp;
  Matches: <strong>{{ count }}</strong>
</p>

<div class="controls">
  <input type="text" id="filterInput" placeholder="Search ticker or company…" oninput="applyFilters()">
  <select id="sectorFilter" onchange="applyFilters()">
    <option value="">All Sectors</option>
    {% for sector in sectors %}
    <option value="{{ sector }}">{{ sector }}</option>
    {% endfor %}
  </select>
  <select id="severityFilter" onchange="applyFilters()">
    <option value="">All Severity</option>
    <option value="severe">Severe (≥75%)</option>
    <option value="significant">Significant (≥50%)</option>
  </select>
</div>

<p class="summary-bar" id="visibleCount">Showing {{ count }} stocks</p>

<div class="table-wrap">
  <table id="stockTable">
    <thead>
      <tr>
        <th data-col="0" data-type="str">Ticker</th>
        <th data-col="1" data-type="str">Company</th>
        <th data-col="2" data-type="str">Sector</th>
        <th data-col="3" data-type="num">Current Price</th>
        <th data-col="4" data-type="num">ATH Price</th>
        <th data-col="5" data-type="str">ATH Date</th>
        <th data-col="6" data-type="num">% Decline ▼</th>
        <th data-col="7" data-type="num">Mkt Cap ($B)</th>
      </tr>
    </thead>
    <tbody id="tableBody">
      {% if rows %}
        {% for row in rows %}
        <tr class="{{ row.severity }}"
            data-sector="{{ row.sector }}"
            data-severity="{{ row.severity }}">
          <td><span class="ticker">{{ row.ticker }}</span></td>
          <td>{{ row.name }}</td>
          <td>{{ row.sector }}</td>
          <td>${{ "%.2f" | format(row.current_price) }}</td>
          <td>${{ "%.2f" | format(row.ath_price) }}</td>
          <td>{{ row.ath_date }}</td>
          <td><span class="pct {{ row.severity }}">-{{ row.pct_decline }}%</span></td>
          <td>${{ "%.1f" | format(row.market_cap_b) }}B</td>
        </tr>
        {% endfor %}
      {% else %}
        <tr>
          <td colspan="8" class="no-results">
            No stocks currently meet the criteria (down {{ threshold | int }}%+ from ATH with market cap ≥${{ min_market_cap_b | int }}B).
          </td>
        </tr>
      {% endif %}
    </tbody>
  </table>
</div>

<script>
  // --- Sorting ---
  let sortCol = 6;        // default: % Decline column
  let sortAsc = false;    // default: descending (worst first)

  document.querySelectorAll('#stockTable thead th').forEach(th => {
    th.addEventListener('click', () => {
      const col = parseInt(th.dataset.col);
      if (sortCol === col) {
        sortAsc = !sortAsc;
      } else {
        sortCol = col;
        sortAsc = th.dataset.type === 'str';  // strings default asc, numbers default desc
      }
      sortTable();
      updateHeaderArrows();
    });
  });

  function sortTable() {
    const tbody = document.getElementById('tableBody');
    const rows = Array.from(tbody.querySelectorAll('tr[data-sector]'));
    const th = document.querySelector(`#stockTable thead th[data-col="${sortCol}"]`);
    const isNum = th && th.dataset.type === 'num';

    rows.sort((a, b) => {
      let aVal = a.cells[sortCol].textContent.trim();
      let bVal = b.cells[sortCol].textContent.trim();
      if (isNum) {
        aVal = parseFloat(aVal.replace(/[^0-9.\-]/g, '')) || 0;
        bVal = parseFloat(bVal.replace(/[^0-9.\-]/g, '')) || 0;
        return sortAsc ? aVal - bVal : bVal - aVal;
      }
      return sortAsc ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
    });
    rows.forEach(r => tbody.appendChild(r));
  }

  function updateHeaderArrows() {
    document.querySelectorAll('#stockTable thead th').forEach(th => {
      // Strip any existing arrow
      th.textContent = th.textContent.replace(/ [▲▼]$/, '');
      if (parseInt(th.dataset.col) === sortCol) {
        th.textContent += sortAsc ? ' ▲' : ' ▼';
      }
    });
  }

  // --- Filtering ---
  function applyFilters() {
    const text = document.getElementById('filterInput').value.toLowerCase();
    const sector = document.getElementById('sectorFilter').value;
    const severity = document.getElementById('severityFilter').value;
    let visible = 0;

    document.querySelectorAll('#tableBody tr[data-sector]').forEach(row => {
      const matchText = !text ||
        row.cells[0].textContent.toLowerCase().includes(text) ||
        row.cells[1].textContent.toLowerCase().includes(text);
      const matchSector = !sector || row.dataset.sector === sector;
      const matchSeverity = !severity || row.dataset.severity === severity;
      const show = matchText && matchSector && matchSeverity;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });

    document.getElementById('visibleCount').textContent = `Showing ${visible} stocks`;
  }

  // Initialize arrows
  updateHeaderArrows();
</script>

</body>
</html>
